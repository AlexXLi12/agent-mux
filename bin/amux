#!/usr/bin/env zsh
# amux - terminal-native agent sub-tabs for tmux
#
# Each home window holds exactly one agent pane (no source pane, no zoom).
# Inactive agents live in a hidden stash session (_amux_<session>), each
# in its own window.  Switching uses swap-pane -- only two panes resize
# and nothing appears in the main status bar.  When all agents die the
# home window simply closes.
set -uo pipefail

AMUX_BIN="${0:A}"

# --- Agent configuration ---
typeset -A AGENT_CMD
AGENT_CMD=(
  claude       "claude"
  claude-trust "claude --dangerously-skip-permissions"
  codex        "codex"
  opencode     "opencode"
  cursor       "cursor-agent"
)

typeset -A AGENT_RESUME
AGENT_RESUME=(
  claude       "claude --resume"
  claude-trust "claude --dangerously-skip-permissions --resume"
  codex        "codex resume"
)

# --- Helpers ---

_home_window() {
  tmux display -p '#{window_id}'
}

# Return the focused agent pane in the home window (if any).
_active_agent_pane() {
  local p
  p=$(tmux list-panes -F '#{pane_id}' -f '#{&&:#{@amux-agent},#{pane_active}}' 2>/dev/null | head -1)
  [[ -z "$p" ]] && p=$(tmux list-panes -F '#{pane_id}' -f '#{@amux-agent}' 2>/dev/null | head -1)
  [[ -n "$p" ]] && echo "$p"
  return 0
}

# --- Stash session ---
# Inactive panes live in a detached session named _amux_<session>.
# Each pane gets its own window so stashing never resizes siblings.
# The session auto-destroys when the last pane leaves.

_stash_session_name() {
  local main=$(tmux display -p '#{session_name}')
  echo "_amux_${main}"
}

# Create a new pane running $cmd in the stash session and return its ID.
# Creates the stash session on first call.
_create_in_stash() {
  local work_dir="$1" cmd="$2"
  local stash=$(_stash_session_name)

  if tmux has-session -t "=$stash" 2>/dev/null; then
    tmux new-window -d -t "=$stash:" -c "$work_dir" -P -F '#{pane_id}' "$cmd"
  else
    local w=$(tmux display -p '#{window_width}')
    local h=$(tmux display -p '#{window_height}')
    tmux new-session -d -s "$stash" -x "$w" -y "$h" -c "$work_dir" -P -F '#{pane_id}' "$cmd"
  fi
}

# Swap active agent with target (in stash). No zoom needed -- each
# window holds exactly one pane.
_switch_to() {
  local target="$1"
  local active=$(_active_agent_pane)
  [[ "$active" == "$target" ]] && return 0

  # If target is already in the home window just select it
  local target_win=$(tmux display -t "$target" -p '#{window_id}' 2>/dev/null)
  local home=$(_home_window)
  if [[ "$target_win" == "$home" ]]; then
    tmux select-pane -t "$target"
    _update_window_name "$target"
    return 0
  fi

  # Swap panes across sessions -- active goes to stash, target comes home
  if [[ -n "$active" ]]; then
    tmux swap-pane -s "$active" -t "$target"
    tmux select-window -t "$home"
    tmux select-pane -t "$target"
  fi
  _update_window_name "$target"
  return 0
}

# --- Ordering & naming ---

_next_order() {
  local max=0 home=$(_home_window)
  local order amux_win actual_win
  while IFS=$'\t' read -r order amux_win actual_win; do
    local win="${amux_win:-$actual_win}"
    [[ "$win" != "$home" ]] && continue
    [[ -n "$order" ]] && (( order > max )) && max=$order
  done < <(tmux list-panes -a -F $'#{@amux-order}\t#{@amux-window}\t#{window_id}' -f '#{@amux-agent}' 2>/dev/null)
  echo $(( max + 1 ))
}

_next_name() {
  local max=0 home=$(_home_window)
  local name amux_win actual_win
  while IFS=$'\t' read -r name amux_win actual_win; do
    local win="${amux_win:-$actual_win}"
    [[ "$win" != "$home" ]] && continue
    if [[ "$name" =~ ^agent-([0-9]+)$ ]]; then
      local n=${match[1]}
      (( n > max )) && max=$n
    fi
  done < <(tmux list-panes -a -F $'#{@amux-name}\t#{@amux-window}\t#{window_id}' -f '#{@amux-agent}' 2>/dev/null)
  echo "agent-$(( max + 1 ))"
}

_find_pane() {
  local name="$1" home=$(_home_window)
  local pane_id pane_name amux_win actual_win
  while IFS=$'\t' read -r pane_id pane_name amux_win actual_win; do
    local win="${amux_win:-$actual_win}"
    if [[ "$pane_name" == "$name" && "$win" == "$home" ]]; then
      echo "$pane_id"
      return 0
    fi
  done < <(tmux list-panes -a -F $'#{pane_id}\t#{@amux-name}\t#{@amux-window}\t#{window_id}' -f '#{@amux-agent}' 2>/dev/null)
  return 1
}

_name_exists() {
  [[ -n "$(_find_pane "$1")" ]]
}

_is_known_option() {
  case "${1:-}" in
    --type|--name|--resume|--trust|--dir|--target|--)
      return 0 ;;
    *)
      return 1 ;;
  esac
}

_require_value() {
  local flag="$1" value="${2-}"
  if [[ -z "$value" ]] || _is_known_option "$value"; then
    echo "Error: $flag requires a value" >&2
    return 1
  fi
}

# All agent pane IDs for a home window, sorted by order.
# Uses list-panes -a to find panes across both main and stash sessions.
# Legacy panes (missing @amux-window) fall back to their actual window.
_agent_pane_ids() {
  local home="${1:-$(_home_window)}"
  local pane_id order amux_win actual_win
  local -a items=()
  while IFS=$'\t' read -r pane_id order amux_win actual_win; do
    local win="${amux_win:-$actual_win}"
    [[ "$win" != "$home" ]] && continue
    items+=("${order:-0}:$pane_id")
  done < <(tmux list-panes -a -F $'#{pane_id}\t#{@amux-order}\t#{@amux-window}\t#{window_id}' -f '#{@amux-agent}' 2>/dev/null)
  (( ${#items[@]} == 0 )) && return 0
  printf '%s\n' "${items[@]}" | sort -t: -k1 -n | cut -d: -f2
}

# Accept optional target pane ID; defaults to current pane.
# Derives the home window from the target so this works correctly
# even when called right after swap-pane.
_update_window_name() {
  local target="${1:-}"
  local t_flag=()
  [[ -n "$target" ]] && t_flag=(-t "$target")

  local is_agent=$(tmux display "${t_flag[@]}" -p '#{@amux-agent}' 2>/dev/null)
  [[ "$is_agent" != "1" ]] && return 0

  # Derive home window: prefer @amux-window metadata, fall back to actual
  local home
  if [[ -n "$target" ]]; then
    home=$(tmux display -t "$target" -p '#{@amux-window}' 2>/dev/null)
    [[ -z "$home" ]] && home=$(tmux display -t "$target" -p '#{window_id}' 2>/dev/null)
  fi

  local current=$(tmux display "${t_flag[@]}" -p '#{@amux-name}')
  local current_id=$(tmux display "${t_flag[@]}" -p '#{pane_id}')
  local total=0 idx=0 i=0
  local pid
  while IFS= read -r pid; do
    (( total++ ))
    (( i++ ))
    [[ "$pid" == "$current_id" ]] && idx=$i
  done < <(_agent_pane_ids ${home:+"$home"})

  if (( total > 0 && idx > 0 )); then
    tmux rename-window "${t_flag[@]}" "$current [$idx/$total]"
  fi
}

# --- Core commands ---

cmd_new() {
  local type="" name="" resume=false trust=false
  local work_dir="$PWD" target=""

  while (( $# > 0 )); do
    case "$1" in
      --type)    _require_value "$1" "${2-}" || return 1; type="$2"; shift 2 ;;
      --name)    _require_value "$1" "${2-}" || return 1; name="$2"; shift 2 ;;
      --resume)  resume=true; shift ;;
      --trust)   trust=true; shift ;;
      --dir)     _require_value "$1" "${2-}" || return 1; work_dir="$2"; shift 2 ;;
      --target)  _require_value "$1" "${2-}" || return 1; target="$2"; shift 2 ;;
      --)        shift; break ;;
      *)         echo "Error: unknown option: $1" >&2; return 1 ;;
    esac
  done

  # Interactive: show menu
  if [[ -z "$type" ]]; then
    cmd__menu "$work_dir"
    return
  fi

  # Adjust type for trust
  if [[ "$trust" == true && "$type" == "claude" ]]; then
    type="claude-trust"
  fi

  # Determine command
  local cmd
  if [[ "$resume" == true ]]; then
    cmd="${AGENT_RESUME[$type]:-}"
    if [[ -z "$cmd" ]]; then
      echo "Error: resume not supported for $type" >&2
      return 1
    fi
  else
    cmd="${AGENT_CMD[$type]:-}"
    if [[ -z "$cmd" ]]; then
      echo "Error: unknown agent type: $type" >&2
      return 1
    fi
  fi

  # Auto-generate name
  [[ -z "$name" ]] && name=$(_next_name)
  if _name_exists "$name"; then
    echo "Error: agent '$name' already exists" >&2
    return 1
  fi

  local home_win=$(_home_window)
  local active=$(_active_agent_pane)
  # Capture current pane NOW, before _create_in_stash may shift server context
  local current_pane=$(tmux display -p '#{pane_id}')

  # Always create the new agent in the stash session
  local new_pane
  new_pane=$(_create_in_stash "$work_dir" "$cmd")

  # Set metadata on the new pane
  tmux set-option -p -t "$new_pane" @amux-agent 1
  tmux set-option -p -t "$new_pane" @amux-name "$name"
  tmux set-option -p -t "$new_pane" @amux-type "${type%-trust}"
  tmux set-option -p -t "$new_pane" @amux-window "$home_win"
  tmux set-option -p -t "$new_pane" @amux-order "$(_next_order)"

  # Show agent name as pane border title
  tmux set-option -p -t "$new_pane" pane-border-status top
  tmux set-option -p -t "$new_pane" pane-border-format " #{@amux-name} (#{@amux-type}) "

  # Keep dead panes alive so the window survives, then auto-swap next agent in
  tmux set-option -p -t "$new_pane" remain-on-exit on
  tmux set-hook -p -t "$new_pane" pane-died "run-shell '$AMUX_BIN _pane_died #{pane_id}'"

  # Swap out whatever is in the home window (agent or original shell)
  local swap_out="${active:-$current_pane}"

  # If swapping out the original shell, tag it so we can restore it later
  if [[ -z "$active" ]]; then
    tmux set-option -p -t "$swap_out" @amux-shell "$home_win"
  fi

  tmux swap-pane -s "$swap_out" -t "$new_pane"

  # After swap, focus may follow the old pane into the stash.
  # Explicitly switch back to the home window and select the new agent.
  tmux select-window -t "$home_win"
  tmux select-pane -t "$new_pane"

  # Update window name
  _update_window_name "$new_pane"
}

cmd_ls() {
  local active=$(_active_agent_pane)
  local found=false

  printf "  %-15s %-10s %-10s %-8s\n" "NAME" "TYPE" "STATE" "PID"

  local pid
  while IFS= read -r pid; do
    found=true
    local marker=" "
    [[ "$pid" == "$active" ]] && marker="*"

    local title=$(tmux display -t "$pid" -p '#{@amux-name}')
    local agent_type=$(tmux display -t "$pid" -p '#{@amux-type}')
    local dead=$(tmux display -t "$pid" -p '#{pane_dead}')
    local dead_status=$(tmux display -t "$pid" -p '#{pane_dead_status}')
    local pane_pid=$(tmux display -t "$pid" -p '#{pane_pid}')

    local state="running"
    [[ "$dead" == "1" ]] && { state="dead($dead_status)"; pane_pid="-"; }
    [[ -z "$agent_type" ]] && agent_type="?"

    printf "%s %-15s %-10s %-10s %-8s\n" "$marker" "$title" "$agent_type" "$state" "$pane_pid"
  done < <(_agent_pane_ids)

  if [[ "$found" == false ]]; then
    echo "  (no agents)"
  fi
}

cmd_next() {
  local -a panes
  local output=$(_agent_pane_ids)
  [[ -z "$output" ]] && return 0
  panes=("${(@f)output}")
  (( ${#panes[@]} <= 1 )) && return 0

  local current=$(_active_agent_pane)
  [[ -z "$current" ]] && current=$(tmux display -p '#{pane_id}')

  local idx=0
  for (( i = 1; i <= ${#panes[@]}; i++ )); do
    [[ "${panes[$i]}" == "$current" ]] && { idx=$i; break; }
  done

  local next_idx
  if (( idx == 0 )); then
    next_idx=1
  else
    next_idx=$(( (idx % ${#panes[@]}) + 1 ))
  fi

  _switch_to "${panes[$next_idx]}"
}

cmd_prev() {
  local -a panes
  local output=$(_agent_pane_ids)
  [[ -z "$output" ]] && return 0
  panes=("${(@f)output}")
  (( ${#panes[@]} <= 1 )) && return 0

  local current=$(_active_agent_pane)
  [[ -z "$current" ]] && current=$(tmux display -p '#{pane_id}')

  local idx=0
  for (( i = 1; i <= ${#panes[@]}; i++ )); do
    [[ "${panes[$i]}" == "$current" ]] && { idx=$i; break; }
  done

  local prev_idx
  if (( idx == 0 )); then
    prev_idx=${#panes[@]}
  else
    prev_idx=$(( ((idx - 2 + ${#panes[@]}) % ${#panes[@]}) + 1 ))
  fi

  _switch_to "${panes[$prev_idx]}"
}

cmd_go() {
  local name="${1:-}"
  [[ -z "$name" ]] && { echo "Usage: amux go <name>" >&2; return 1; }

  local pane=$(_find_pane "$name")
  [[ -z "$pane" ]] && { echo "Error: agent '$name' not found" >&2; return 1; }

  _switch_to "$pane"
}

cmd_kill() {
  local target="${1:-}"

  if [[ "$target" == "--all" ]]; then
    local pid
    while IFS= read -r pid; do
      tmux send-keys -t "$pid" "/exit" Enter 2>/dev/null
    done < <(_agent_pane_ids)

    # Wait for graceful exit
    sleep 3

    # Force-kill survivors
    while IFS= read -r pid; do
      tmux kill-pane -t "$pid" 2>/dev/null
    done < <(_agent_pane_ids)

  elif [[ "$target" == "--dead" ]]; then
    local pid
    while IFS= read -r pid; do
      local dead=$(tmux display -t "$pid" -p '#{pane_dead}' 2>/dev/null)
      [[ "$dead" == "1" ]] && tmux kill-pane -t "$pid" 2>/dev/null
    done < <(_agent_pane_ids)

  elif [[ -n "$target" ]]; then
    local pane=$(_find_pane "$target")
    [[ -z "$pane" ]] && { echo "Error: agent '$target' not found" >&2; return 1; }

    # If killing the active agent and others exist, swap to next first
    local active=$(_active_agent_pane)
    if [[ "$pane" == "$active" ]]; then
      cmd_next 2>/dev/null
    fi

    tmux send-keys -t "$pane" "/exit" Enter 2>/dev/null

    local i dead
    for i in {1..6}; do
      sleep 0.5
      dead=$(tmux display -t "$pane" -p '#{pane_dead}' 2>/dev/null || echo "1")
      [[ "$dead" == "1" ]] && break
    done
    tmux kill-pane -t "$pane" 2>/dev/null
  else
    echo "Usage: amux kill <name|--dead|--all>" >&2
    return 1
  fi
}

cmd_rename() {
  local old="${1:-}" new="${2:-}"
  [[ -z "$old" || -z "$new" ]] && { echo "Usage: amux rename <old> <new>" >&2; return 1; }

  local pane=$(_find_pane "$old")
  [[ -z "$pane" ]] && { echo "Error: agent '$old' not found" >&2; return 1; }
  if [[ "$old" != "$new" ]] && _name_exists "$new"; then
    echo "Error: agent '$new' already exists" >&2
    return 1
  fi

  tmux set-option -p -t "$pane" @amux-name "$new"
  _update_window_name
}

cmd_move() {
  local name="${1:-}" direction="${2:-}"
  [[ -z "$name" || -z "$direction" ]] && { echo "Usage: amux move <name> <up|down>" >&2; return 1; }

  local pane=$(_find_pane "$name")
  [[ -z "$pane" ]] && { echo "Error: agent '$name' not found" >&2; return 1; }

  # Get ordered list of agent pane IDs
  local -a panes
  local output=$(_agent_pane_ids)
  [[ -z "$output" ]] && return 0
  panes=("${(@f)output}")

  # Find current position
  local idx=0
  for (( i = 1; i <= ${#panes[@]}; i++ )); do
    if [[ "${panes[$i]}" == "$pane" ]]; then
      idx=$i
      break
    fi
  done
  (( idx == 0 )) && return 1

  local swap_idx
  case "$direction" in
    up)
      swap_idx=$(( ((idx - 2 + ${#panes[@]}) % ${#panes[@]}) + 1 ))
      ;;
    down)
      swap_idx=$(( (idx % ${#panes[@]}) + 1 ))
      ;;
    *)
      echo "Error: direction must be 'up' or 'down'" >&2
      return 1
      ;;
  esac

  # Swap order values (panes may be in different sessions now)
  local order_a=$(tmux display -t "$pane" -p '#{@amux-order}')
  local order_b=$(tmux display -t "${panes[$swap_idx]}" -p '#{@amux-order}')
  tmux set-option -p -t "$pane" @amux-order "$order_b"
  tmux set-option -p -t "${panes[$swap_idx]}" @amux-order "$order_a"

  _update_window_name "$pane"
}

cmd_scratch() {
  if [[ $# -eq 0 ]]; then
    # Interactive: show agent picker for scratch popup
    cmd__scratch_menu
    return
  fi

  local type="$1"; shift
  local trust=false

  # Parse optional flags
  while (( $# > 0 )); do
    case "$1" in
      --trust) trust=true; shift ;;
      --)      shift; break ;;
      *)       break ;;
    esac
  done

  local cmd
  if (( $# > 0 )); then
    # Raw command after --
    cmd="$*"
  else
    if [[ "$trust" == true && "$type" == "claude" ]]; then
      type="claude-trust"
    fi
    cmd="${AGENT_CMD[$type]:-}"
    [[ -z "$cmd" ]] && { echo "Error: unknown agent type: $type" >&2; return 1; }
  fi

  tmux display-popup -E -w 85% -h 85% -b rounded -T " scratch ($type) " "$cmd"
}

cmd_send() {
  local name="${1:-}"; shift 2>/dev/null || true
  [[ -z "$name" ]] && { echo "Usage: amux send <name> <keys...>" >&2; return 1; }

  local pane=$(_find_pane "$name")
  [[ -z "$pane" ]] && { echo "Error: agent '$name' not found" >&2; return 1; }

  tmux send-keys -t "$pane" "$@"
}

cmd_respawn() {
  local name="${1:-}"; shift 2>/dev/null || true
  [[ -z "$name" ]] && { echo "Usage: amux respawn <name> [-- cmd...]" >&2; return 1; }

  local pane=$(_find_pane "$name")
  [[ -z "$pane" ]] && { echo "Error: agent '$name' not found" >&2; return 1; }

  local cmd="claude"
  if [[ "${1:-}" == "--" ]]; then
    shift
    cmd="$*"
  fi

  tmux respawn-pane -k -t "$pane" "$cmd"
}

cmd_log() {
  local name="${1:-}"
  [[ -z "$name" ]] && { echo "Usage: amux log <name>" >&2; return 1; }

  local pane=$(_find_pane "$name")
  [[ -z "$pane" ]] && { echo "Error: agent '$name' not found" >&2; return 1; }

  tmux capture-pane -t "$pane" -p -S -
}

# --- Internal commands (used by tmux keybindings) ---

cmd__scratch_menu() {
  local self="$AMUX_BIN"

  tmux display-menu -T " Scratch Agent " \
    "claude"                c "run-shell '$self scratch claude'" \
    "claude (auto-approve)" p "run-shell '$self scratch claude --trust'" \
    ""                      "" "" \
    "codex"                 x "run-shell '$self scratch codex'" \
    ""                      "" "" \
    "opencode"              o "run-shell '$self scratch opencode'" \
    "cursor agent"          u "run-shell '$self scratch cursor'"
}

cmd__menu() {
  local work_dir="${1:-$(tmux display -p '#{pane_current_path}' 2>/dev/null || echo "$PWD")}"
  local self="$AMUX_BIN"

  tmux display-menu -T " New Agent " \
    "claude"                        c "run-shell '$self _create claude \"$work_dir\"'" \
    "claude (auto-approve)"         p "run-shell '$self _create claude-trust \"$work_dir\"'" \
    "claude (resume)"               C "run-shell '$self new --type claude --resume --dir \"$work_dir\"'" \
    "claude (auto-approve, resume)" P "run-shell '$self new --type claude --trust --resume --dir \"$work_dir\"'" \
    ""                              "" "" \
    "codex"                         x "run-shell '$self _create codex \"$work_dir\"'" \
    "codex (resume)"                X "run-shell '$self new --type codex --resume --dir \"$work_dir\"'" \
    ""                              "" "" \
    "opencode"                      o "run-shell '$self _create opencode \"$work_dir\"'" \
    "cursor agent"                  u "run-shell '$self _create cursor \"$work_dir\"'"
}

cmd__create() {
  local type="$1"
  local work_dir="${2:-$(tmux display -p '#{pane_current_path}' 2>/dev/null || echo "$PWD")}"
  local target=$(tmux display -p '#{pane_id}' 2>/dev/null)

  cmd_new --type "$type" --dir "$work_dir" --target "$target"
}

cmd__pick() {
  local self="$AMUX_BIN"
  local -a menu_args=()
  local idx=0
  local has_agents=false
  local has_dead=false
  local active=$(_active_agent_pane)

  local pid
  while IFS= read -r pid; do
    has_agents=true
    (( idx++ ))
    local title=$(tmux display -t "$pid" -p '#{@amux-name}')
    local agent_type=$(tmux display -t "$pid" -p '#{@amux-type}')
    local dead=$(tmux display -t "$pid" -p '#{pane_dead}')
    local label="$title ($agent_type)"
    [[ "$pid" == "$active" ]] && label="* $label"
    [[ "$dead" == "1" ]] && { label="$label [dead]"; has_dead=true; }
    menu_args+=("$label" "$idx" "run-shell '$self go \"$title\"'")
  done < <(_agent_pane_ids)

  local work_dir=$(tmux display -p '#{pane_current_path}' 2>/dev/null || echo "$PWD")

  # --- Actions ---
  menu_args+=("" "" "")
  menu_args+=("+ New agent"    "n" "run-shell '$self _menu \"$work_dir\"'")
  menu_args+=("Scratch popup"  "s" "run-shell '$self scratch'")

  if [[ "$has_agents" == true ]]; then
    menu_args+=("" "" "")
    menu_args+=("Move up"          "<" "run-shell '$self _move_current up'")
    menu_args+=("Move down"        ">" "run-shell '$self _move_current down'")
    menu_args+=("Rename current"   "r" "run-shell '$self _rename_current'")
    menu_args+=("Log current"      "l" "run-shell '$self _log_current'")
    menu_args+=("Kill current"     "x" "run-shell '$self _kill_current'")
    menu_args+=("Kill agent..."    "d" "run-shell '$self _kill_pick'")
    if [[ "$has_dead" == true ]]; then
      menu_args+=("Respawn current"  "R" "run-shell '$self _respawn_current'")
      menu_args+=("Kill dead"        "D" "run-shell '$self kill --dead'")
    fi
    menu_args+=("Kill all"        "X" "run-shell '$self kill --all'")
  fi

  menu_args+=("" "" "")
  menu_args+=("Keybindings"    "?" "run-shell '$self _keybindings'")

  tmux display-menu -T " Agents " "${menu_args[@]}"
}

cmd__kill_pick() {
  local self="$AMUX_BIN"
  local -a menu_args=()
  local idx=0

  local pid
  while IFS= read -r pid; do
    (( idx++ ))
    local title=$(tmux display -t "$pid" -p '#{@amux-name}')
    local agent_type=$(tmux display -t "$pid" -p '#{@amux-type}')
    local dead=$(tmux display -t "$pid" -p '#{pane_dead}')
    local label="$title ($agent_type)"
    [[ "$dead" == "1" ]] && label="$label [dead]"
    menu_args+=("$label" "$idx" "run-shell '$self _kill_pane $pid'")
  done < <(_agent_pane_ids)

  (( ${#menu_args[@]} > 0 )) && tmux display-menu -T " Kill Agent " "${menu_args[@]}"
}

cmd__kill_pane() {
  local pane="$1"
  [[ -z "$pane" ]] && return 1
  local self="$AMUX_BIN"
  tmux send-keys -t "$pane" "/exit" Enter 2>/dev/null
  ( sleep 3 && tmux kill-pane -t "$pane" 2>/dev/null; "$self" _update_name 2>/dev/null ) &!
}

cmd__pane_died() {
  local dead_pane="${1:-$(tmux display -p '#{pane_id}' 2>/dev/null)}"
  [[ -z "$dead_pane" ]] && return 0

  # Find an alive agent to swap in
  local alive=""
  local pid
  while IFS= read -r pid; do
    [[ "$pid" == "$dead_pane" ]] && continue
    local d=$(tmux display -t "$pid" -p '#{pane_dead}' 2>/dev/null)
    if [[ "$d" != "1" ]]; then
      alive="$pid"
      break
    fi
  done < <(_agent_pane_ids)

  if [[ -n "$alive" ]]; then
    # Swap the alive agent into the home window, then kill the dead pane
    _switch_to "$alive"
    tmux kill-pane -t "$dead_pane" 2>/dev/null
  else
    # Last agent -- restore the original shell if we stashed one
    local home=$(_home_window)
    local shell_pane=""
    local sp sw
    while IFS=$'\t' read -r sp sw; do
      if [[ "$sw" == "$home" ]]; then
        shell_pane="$sp"
        break
      fi
    done < <(tmux list-panes -a -F $'#{pane_id}\t#{@amux-shell}' -f '#{@amux-shell}' 2>/dev/null)

    if [[ -n "$shell_pane" ]]; then
      tmux swap-pane -s "$dead_pane" -t "$shell_pane"
      tmux kill-pane -t "$dead_pane" 2>/dev/null
      tmux set-option -pu -t "$shell_pane" @amux-shell
    else
      # No original shell found -- respawn a fresh one
      tmux respawn-pane -k -t "$dead_pane"
    fi
  fi
}

cmd__kill_current() {
  local is_agent=$(tmux display -p '#{@amux-agent}' 2>/dev/null)
  if [[ "$is_agent" == "1" ]]; then
    local current=$(tmux display -p '#{pane_id}')
    local self="$AMUX_BIN"
    # Switch to the next agent before killing this one
    cmd_next 2>/dev/null
    tmux send-keys -t "$current" "/exit" Enter 2>/dev/null
    ( sleep 3 && tmux kill-pane -t "$current" 2>/dev/null; "$self" _update_name 2>/dev/null ) &!
  fi
  return 0
}

cmd__move_current() {
  local direction="${1:-}"
  local is_agent=$(tmux display -p '#{@amux-agent}' 2>/dev/null)
  if [[ "$is_agent" == "1" ]]; then
    local name=$(tmux display -p '#{@amux-name}' 2>/dev/null)
    cmd_move "$name" "$direction" 2>/dev/null
  fi
  return 0
}

cmd__rename_current() {
  local new_name="${1:-}"
  if [[ -n "$new_name" ]]; then
    # Called with a name directly (e.g., from CLI)
    local is_agent=$(tmux display -p '#{@amux-agent}' 2>/dev/null)
    if [[ "$is_agent" == "1" ]]; then
      local target=$(tmux display -p '#{pane_id}')
      tmux set-option -p -t "$target" @amux-name "$new_name"
      _update_window_name "$target"
    fi
  else
    # Interactive: open a popup to get the name
    local target=$(tmux display -p '#{pane_id}' 2>/dev/null)
    local self="$AMUX_BIN"
    local current_name=$(tmux display -p '#{@amux-name}' 2>/dev/null)
    tmux display-popup -E -w 50% -h 3 -T " Rename agent " \
      "printf '($current_name) > ' && read -r name && [ -n \"\$name\" ] && exec \"$self\" rename \"$current_name\" \"\$name\""
  fi
  return 0
}

cmd__log_current() {
  local is_agent=$(tmux display -p '#{@amux-agent}' 2>/dev/null)
  if [[ "$is_agent" == "1" ]]; then
    local pane=$(tmux display -p '#{pane_id}')
    local title=$(tmux display -p '#{@amux-name}')
    tmux display-popup -E -w 85% -h 85% -T " log: $title " \
      "tmux capture-pane -t '$pane' -p -S - | less -R"
  fi
  return 0
}

cmd__respawn_current() {
  local is_agent=$(tmux display -p '#{@amux-agent}' 2>/dev/null)
  local is_dead=$(tmux display -p '#{pane_dead}' 2>/dev/null)
  if [[ "$is_agent" == "1" && "$is_dead" == "1" ]]; then
    local agent_type=$(tmux display -p '#{@amux-type}' 2>/dev/null)
    local cmd="${AGENT_CMD[${agent_type:-claude}]:-claude}"
    tmux respawn-pane -k "$cmd"
  fi
  return 0
}

cmd__keybindings() {
  tmux display-popup -E -w 40 -h 12 -T " amux keybindings " \
    "printf '\n  prefix a    Agent picker\n  prefix A    New agent menu\n  Alt-]       Next agent\n  Alt-[       Previous agent\n  Alt-a       Scratch popup\n\n  Press any key to close\n' && read -rsk1"
}

cmd__status() {
  local count=0 running=0 dead_count=0
  local pid
  while IFS= read -r pid; do
    (( count++ ))
    local dead=$(tmux display -t "$pid" -p '#{pane_dead}' 2>/dev/null)
    if [[ "$dead" == "1" ]]; then
      (( dead_count++ ))
    else
      (( running++ ))
    fi
  done < <(_agent_pane_ids)

  if (( count > 0 )); then
    if (( dead_count > 0 )); then
      printf " %d(%d dead)" "$count" "$dead_count"
    else
      printf " %d" "$count"
    fi
  fi
  return 0
}

# --- Main dispatch ---

main() {
  # Require tmux
  if [[ -z "${TMUX:-}" ]]; then
    echo "Error: amux must be run inside tmux" >&2
    exit 1
  fi

  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    new)            cmd_new "$@" ;;
    ls|list)        cmd_ls "$@" ;;
    next)           cmd_next "$@" ;;
    prev)           cmd_prev "$@" ;;
    go)             cmd_go "$@" ;;
    kill)           cmd_kill "$@" ;;
    rename)         cmd_rename "$@" ;;
    move)           cmd_move "$@" ;;
    scratch)        cmd_scratch "$@" ;;
    send)           cmd_send "$@" ;;
    respawn)        cmd_respawn "$@" ;;
    log)            cmd_log "$@" ;;
    _menu)          cmd__menu "$@" ;;
    _create)        cmd__create "$@" ;;
    _pick)          cmd__pick "$@" ;;
    _pane_died)       cmd__pane_died "$@" ;;
    _kill_current)    cmd__kill_current "$@" ;;
    _kill_pick)       cmd__kill_pick "$@" ;;
    _kill_pane)       cmd__kill_pane "$@" ;;
    _move_current)    cmd__move_current "$@" ;;
    _rename_current)  cmd__rename_current "$@" ;;
    _log_current)     cmd__log_current "$@" ;;
    _respawn_current) cmd__respawn_current "$@" ;;
    _update_name)     _update_window_name "$@" ;;
    _keybindings)     cmd__keybindings "$@" ;;
    _status)          cmd__status "$@" ;;
    help|--help|-h)
      cat <<'EOF'
amux - terminal-native agent sub-tabs for tmux

Usage: amux <command> [args]

Commands:
  new [--type T] [--name N]                Create new agent (interactive if no --type)
  ls                                        List agents in current window
  next / prev                               Cycle to next/prev agent
  go <name>                                 Switch to agent by name
  kill <name|--dead|--all>                  Kill agent(s)
  rename <old> <new>                        Rename agent
  move <name> <up|down>                     Reorder agent
  scratch [-- cmd...]                       Popup scratch agent
  send <name> <keys...>                     Send keys to agent
  respawn <name> [-- cmd...]                Restart dead agent
  log <name>                                Capture agent pane output

Agent types: claude, codex, opencode, cursor
Flags: --trust (auto-approve), --resume

Keybindings:
  prefix a    Agent picker
  prefix A    New agent menu
  Alt-]       Next agent
  Alt-[       Previous agent
  Alt-a       Scratch popup
EOF
      ;;
    *)
      echo "Unknown command: $cmd (try 'amux help')" >&2
      return 1
      ;;
  esac
}

main "$@"
