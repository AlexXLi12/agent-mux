#compdef amux

_amux() {
  local -a commands
  commands=(
    'new:Create new agent'
    'ls:List agents'
    'next:Next agent'
    'prev:Previous agent'
    'go:Switch to agent by name'
    'kill:Kill agent(s)'
    'rename:Rename agent'
    'move:Reorder agent'
    'scratch:Popup scratch agent'
    'send:Send keys to agent'
    'respawn:Restart dead agent'
    'log:Capture agent output'
    'help:Show help'
  )

  local -a agents
  agents=($(tmux list-panes -F '#{pane_title}' -f '#{@amux-agent}' 2>/dev/null))

  _arguments '1:command:->cmd' '*:args:->args'

  case $state in
    cmd)
      _describe 'command' commands
      ;;
    args)
      case ${words[2]} in
        move)
          if (( CURRENT == 3 )); then
            _describe 'agent' agents
          elif (( CURRENT == 4 )); then
            local -a dirs=('up:Move earlier in order' 'down:Move later in order')
            _describe 'direction' dirs
          fi
          ;;
        go|send|respawn|log)
          _describe 'agent' agents
          ;;
        rename)
          if (( CURRENT == 3 )); then
            _describe 'agent' agents
          fi
          ;;
        kill)
          local -a kill_opts
          kill_opts=('--dead:Kill dead agents' '--all:Kill all agents')
          _alternative \
            'agents:agent:_describe "agent" agents' \
            'flags:flag:_describe "flag" kill_opts'
          ;;
        new)
          _arguments \
            '--type[Agent type]:type:(claude codex opencode cursor)' \
            '--name[Agent name]:name:' \
            '--trust[Auto-approve mode]' \
            '--resume[Resume previous session]'
          ;;
      esac
      ;;
  esac
}

_amux "$@"
